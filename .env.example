# Database
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# App URL used when building asset links for publishing
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini-powered portrait artwork
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Feed sync
# Use SPORTS_SYNC_PROVIDER=thesportsdb to pull real upcoming fixtures into the admin staging queue.
# Optional TheSportsDB league ids. If omitted, the app uses a broad built-in set of major
# competitions across football, basketball, baseball, hockey, cricket, rugby, motorsport,
# fighting, tennis, golf, and American football.
SPORTS_SYNC_PROVIDER=thesportsdb
SPORTSDB_API_KEY=123
SPORTSDB_LEAGUE_IDS=4328,4335,4387

# Optional custom JSON feed instead of TheSportsDB.
# Accepts either a JSON array or { "matches": [...] }.
SPORTS_SYNC_FEED_URL=

# Optional: webhook that receives generated assets for publishing
PUBLISH_WEBHOOK_URL=
# Optional: number of ready card assets to publish per cron/manual queue run.
# Keep this small in serverless production if Facebook Story posting is enabled.
PUBLISH_BATCH_SIZE=2

# Facebook Page Story auto-publish (optional). Page token needs pages_show_list, pages_read_engagement, pages_manage_posts.
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Cron: secret for authenticating hourly unpublished-queue job (Vercel sends as Bearer token)
CRON_SECRET=
