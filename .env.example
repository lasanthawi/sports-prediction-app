# Database
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# App URL used when building asset links for publishing
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini-powered portrait artwork
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Optional: remote fixture/result feed for automation
# Accepts either a JSON array or { "matches": [...] }
# Premium card metadata supported:
# team1Captain, team2Captain, team1Palette, team2Palette, team1FlagColors, team2FlagColors,
# creativeDirection, rivalryTagline, artStyle
SPORTS_SYNC_FEED_URL=

# Optional: webhook that receives generated assets for publishing
PUBLISH_WEBHOOK_URL=
